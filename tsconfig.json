{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "target": "ES2022",
    "types": ["bun-types"]
  },
  "include": [
    "adapters/pi-dev/extension/**/*.ts",
    "reference/**/*.ts",
    "tests/**/*.ts"
  ]
}
